BACKEND_ORIGIN=http://localhost:18311

# Copy this file to `.dev.vars` for local `wrangler dev`.

# Enable auto-reload in development (the Worker injects a tiny polling script)
DEV_AUTORELOAD=1
# Force OAuth redirects back to Vite origin in dev.
# Example: http://localhost:18310 or https://example.com
DEV_ORIGIN=http://localhost:18310

# Security
SESSION_SECRET=a-very-long-and-random-secret-key

# Database
DATABASE_URL=postgres://user:password@localhost:5432/dbname?sslmode=disable

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Instagram OAuth (uses Facebook App credentials - Meta merged the products)
# Note: The "Instagram" button uses FACEBOOK_APP_ID/SECRET
# INSTAGRAM_CLIENT_ID and INSTAGRAM_CLIENT_SECRET are deprecated
INSTAGRAM_VERIFY_TOKEN=your-instagram-verify-token

# Facebook (for Instagram Graph API)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Admin emails (comma-separated) for gating admin subscription endpoints
ADMIN_EMAILS=admin@example.com

# Optional: R2 Bucket for image storage
# (Configure via wrangler.jsonc or wrangler secret put)
# IMAGES=your-r2-bucket-name
